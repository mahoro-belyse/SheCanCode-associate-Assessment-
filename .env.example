APP_TITLE=IgirePay Idempotency Gateway
APP_VERSION=1.0.0
APP_ENV=development

HOST=0.0.0.0
PORT=8000
RELOAD=True

PROCESSING_DELAY_SECONDS=2.0
KEY_TTL_SECONDS=86400
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECONDS=60
